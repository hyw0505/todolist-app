# Test Environment Configuration
NODE_ENV=test
PORT=3001

# JWT secrets (32+ characters for test)
JWT_ACCESS_SECRET=test-access-secret-must-be-32-chars-min!!
JWT_REFRESH_SECRET=test-refresh-secret-must-be-32-chars-min!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting (lower values for faster testing)
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_API_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Encryption
BCRYPT_SALT_ROUNDS=10

# Database (test database)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=todolist_test
DB_USER=todolist-test-user
DB_PASSWORD=todolist-test-pass
DB_POOL_MAX=5
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000
