# ============================================================
# todolist-app Backend 환경변수 템플릿
# 이 파일을 복사하여 .env.development 파일을 생성하세요.
# ============================================================

# 서버 기본 설정
NODE_ENV=development
PORT=3000

# JWT 인증 (최소 32자 이상 랜덤 문자열)
JWT_ACCESS_SECRET=<최소-32자-랜덤-문자열-직접-설정>
JWT_REFRESH_SECRET=<최소-32자-랜덤-문자열-직접-설정>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_API_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# 암호화
BCRYPT_SALT_ROUNDS=10

# 데이터베이스 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=todolist_dev
DB_USER=<db-사용자명>
DB_PASSWORD=<db-비밀번호>
DB_POOL_MAX=10
